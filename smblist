#!/bin/bash
# smblist - Recursively list SMB share contents
#
# Usage:
#   smblist 'user%pass' [shares.txt]            - use existing shares file
#   smblist 'user%pass' -nxc <nxc_output>       - enumerate from nxc output
#   smblist -nxc <nxc_output>                   - just parse nxc into share list
#   smblist 'user%pass' -get '//IP/share/file'  - download a specific file
#   smblist 'user%pass' -gui [paths.txt]        - launch web gui
#   smblist 'user%pass' [shares.txt] -o out.txt - output to file and terminal
#   cat shares.txt | smblist 'user%pass'        - stdin mode

if [ -z "$1" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "Usage: smblist 'user%pass' [shares.txt]"
    echo "       smblist 'user%pass' -nxc <nxc_output_file>"
    echo "       smblist -nxc <nxc_output_file>"
    echo "       smblist 'user%pass' -get '//IP/share/path/to/file'"
    echo "       smblist 'user%pass' -gui [paths.txt]"
    echo "       smblist 'user%pass' [shares.txt] -o output.txt"
    echo ""
    echo "Shares file format (one per line):"
    echo "  //IP/sharename"
    echo "  //IP/share with spaces"
    exit 1
fi

parse_nxc() {
    grep 'READ' "$1" | awk '{
        for(i=1;i<=NF;i++){
            if($i ~ /^READ/){
                share=""
                for(j=5;j<i;j++) share=share($j)(j<i-1?" ":"")
                print "//"$2"/"share
                break
            }
        }
    }' | grep -v 'IPC\$'
}

download_file() {
    fullpath="$1"
    share=$(echo "$fullpath" | grep -oP '//[^/]+/[^/]+')
    filepath=$(echo "$fullpath" | sed "s|$share||")
    dir=$(dirname "$filepath")
    filename=$(basename "$filepath")
    echo "[*] Downloading: $filename"
    echo "[*] From: $share$dir"
    smbclient "$share" -U "$creds" -c "cd \"$dir\"; get \"$filename\"" 2>/dev/null
    if [ -f "$filename" ]; then
        echo "[+] Saved: $(pwd)/$filename"
    else
        echo "[-] Failed: $filename"
    fi
}

run_smblist() {
    while read share; do
        [ -z "$share" ] && continue
        smbclient "$share" -U "$creds" -c 'recurse;ls' 2>/dev/null | python3 -c "
import sys,re
base,path,seen='$share','',set()
for l in sys.stdin:
    l=l.rstrip()
    if l.startswith('\\\\'):
        path=l.strip()
    elif l.strip():
        m=re.match(r'^  (.+?)\\s{2,}(\\w+)\\s',l)
        if not m:continue
        name=m.group(1).strip()
        ftype=m.group(2)
        if name in ('.','..') or 'blocks' in l or ftype=='D':continue
        full=base+path.replace('\\\\','/')+'/'+name
        if full not in seen:
            seen.add(full)
            print(full)
" | if [ -n "$outfile" ]; then tee -a "$outfile"; else cat; fi
    done
}

creds="$1"

if [ "$2" = "-gui" ]; then
    pathsfile="${3:-}"
    python3 - "$creds" "$pathsfile" << 'PYEOF'
import sys, os, threading, webbrowser, subprocess
from http.server import HTTPServer, BaseHTTPRequestHandler
import urllib.parse, json

creds = sys.argv[1] if len(sys.argv) > 1 else ''
pathsfile = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else ''
paths = []
if pathsfile and os.path.exists(pathsfile):
    with open(pathsfile) as f:
        paths = [l.strip() for l in f if l.strip()]

HTML = """<!DOCTYPE html>
