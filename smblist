#!/bin/bash
# smblist - Recursively list SMB share contents
# Usage: smblist 'user%pass' [shares.txt]
#
# Shares file format (one per line):
#   //192.168.1.1/sharename
#   //192.168.1.2/another share
#
# Examples:
#   smblist 'domain/user%pass' shares.txt
#   cat shares.txt | smblist 'domain/user%pass'
#   smblist 'domain/user%pass' <<< '//192.168.1.1/share'

if [ -z "$1" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "Usage: smblist 'user%pass' [shares.txt]"
    echo ""
    echo "Shares file format (one per line):"
    echo "  //IP/sharename"
    echo "  //IP/share with spaces"
    echo ""
    echo "Examples:"
    echo "  smblist 'domain/user%pass' shares.txt"
    echo "  cat shares.txt | smblist 'domain/user%pass'"
    exit 1
fi

creds="$1"
input="${2:--}"

while read share; do
    [ -z "$share" ] && continue
    smbclient "$share" -U "$creds" -c 'recurse;ls' 2>/dev/null | python3 -c "
import sys
base,path,seen='$share','',set()
for l in sys.stdin:
    l=l.rstrip()
    if l.startswith('\\\\'):
        path=l.strip()
    elif l.strip():
        p=l.strip().split()
        if p[0] in ('.','..') or 'blocks' in l or len(p)<2 or p[1]=='D':
            continue
        full=base+path.replace('\\\\','/')+'/'+p[0]
        if full not in seen:
            seen.add(full)
            print(full)
"
