#!/bin/bash
# smblist - Recursively list SMB share contents
#
# Usage:
#   smblist 'user%pass' [shares.txt]              - use existing shares file
#   smblist 'user%pass' -nxc <nxc_output>         - parse existing nxc output
#   smblist -nxc <nxc_output>                     - just parse nxc into share list
#   smblist 'user%pass' -host <host> [hosts.txt]  - run nxc then enumerate
#   smblist 'user%pass' -get '//host/share/file'  - download a specific file
#   smblist 'user%pass' -gui [paths.txt]          - launch web gui
#   smblist 'user%pass' [shares.txt] -o out.txt   - output to file and terminal
#   cat shares.txt | smblist 'user%pass'          - stdin mode

if [ -z "$1" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "Usage: smblist 'user%pass' [shares.txt]"
    echo "       smblist 'user%pass' -nxc <nxc_output_file>"
    echo "       smblist -nxc <nxc_output_file>"
    echo "       smblist 'user%pass' -host <HOST.DOMAIN or IP>"
    echo "       smblist 'user%pass' -host <hosts.txt>"
    echo "       smblist 'user%pass' -get '//host/share/path/to/file'"
    echo "       smblist 'user%pass' -gui [paths.txt]"
    echo "       smblist 'user%pass' [shares.txt] -o output.txt"
    echo ""
    echo "Shares file format (one per line):"
    echo "  //IP/sharename"
    echo "  //hostname.domain/share with spaces"
    exit 1
fi

parse_nxc() {
    python3 -c "
import sys, re
lines = open(sys.argv[1]).readlines()
hostmap = {}
for line in lines:
    nm = re.search(r'\(name:([^)]+)\)', line)
    dm = re.search(r'\(domain:([^)]+)\)', line)
    im = re.search(r'SMB\s+([\d.]+)', line)
    if im and nm and dm:
        hostmap[im.group(1)] = (nm.group(1).strip() + '.' + dm.group(1).strip()).upper()
for line in lines:
    if 'READ' not in line:
        continue
    im = re.search(r'SMB\s+([\d.]+)', line)
    m = re.search(r'SMB\s+[\d.]+\s+\d+\s+\S+\s+(.+?)\s+READ', line)
    if not im or not m:
        continue
    share = m.group(1).strip()
    if share == 'IPC\$':
        continue
    host = hostmap.get(im.group(1), im.group(1))
    print('//' + host + '/' + share)
" "$1"
}

parse_nxc_str() {
    python3 -c "
import sys, re
lines = sys.stdin.readlines()
hostmap = {}
for line in lines:
    nm = re.search(r'\(name:([^)]+)\)', line)
    dm = re.search(r'\(domain:([^)]+)\)', line)
    im = re.search(r'SMB\s+([\d.]+)', line)
    if im and nm and dm:
        hostmap[im.group(1)] = (nm.group(1).strip() + '.' + dm.group(1).strip()).upper()
for line in lines:
    if 'READ' not in line:
        continue
    im = re.search(r'SMB\s+([\d.]+)', line)
    m = re.search(r'SMB\s+[\d.]+\s+\d+\s+\S+\s+(.+?)\s+READ', line)
    if not im or not m:
        continue
    share = m.group(1).strip()
    if share == 'IPC\$':
        continue
    host = hostmap.get(im.group(1), im.group(1))
    print('//' + host + '/' + share)
"
}

download_file() {
    fullpath="$1"
    share=$(echo "$fullpath" | grep -oP '//[^/]+/[^/]+')
    filepath=$(echo "$fullpath" | sed "s|$share||")
    dir=$(dirname "$filepath")
    filename=$(basename "$filepath")
    echo "[*] Downloading: $filename"
    echo "[*] From: $share$dir"
    smbclient "$share" -U "$creds" -c "cd \"$dir\"; get \"$filename\"" 2>/dev/null
    if [ -f "$filename" ]; then
        echo "[+] Saved: $(pwd)/$filename"
    else
        echo "[-] Failed: $filename"
    fi
}

run_smblist() {
    while read share; do
        [ -z "$share" ] && continue
        smbclient "$share" -U "$creds" -c 'recurse;ls' 2>/dev/null | python3 -c "
import sys,re
base,path,seen='$share','',set()
for l in sys.stdin:
    l=l.rstrip()
    if l.startswith('\\\\'):
        path=l.strip()
    elif l.strip():
        m=re.match(r'^  (.+?)\s{2,}(\w+)\s',l)
        if not m:continue
        name=m.group(1).strip()
        ftype=m.group(2)
        if name in ('.','..') or 'blocks' in l or ftype.startswith('D'):continue
        full=base+path.replace('\\\\','/')+'/'+name
        if full not in seen:
            seen.add(full)
            print(full)
" | if [ -n "$outfile" ]; then tee -a "$outfile"; else cat; fi
    done
}

run_host() {
    local target="$1"
    local safe=$(echo "$target" | tr '/' '_')
    local auto_out="smblist_${safe}"
    echo "[*] Running nxc against $target" >&2
    local nxc_out
    nxc_out=$(proxychains netexec smb "$target" -u "$user" -p "$pass" -d "$domain" --shares 2>/dev/null)
    local shares
    shares=$(echo "$nxc_out" | parse_nxc_str)
    if [ -z "$shares" ]; then
        echo "[-] No readable shares found for $target" >&2
        return
    fi
    echo "[*] Saving to $auto_out" >&2
    echo "$shares" | while read share; do
        [ -z "$share" ] && continue
        smbclient "$share" -U "$creds" -c 'recurse;ls' 2>/dev/null | python3 -c "
import sys,re
base,path,seen='$share','',set()
for l in sys.stdin:
    l=l.rstrip()
    if l.startswith('\\\\'):
        path=l.strip()
    elif l.strip():
        m=re.match(r'^  (.+?)\s{2,}(\w+)\s',l)
        if not m:continue
        name=m.group(1).strip()
        ftype=m.group(2)
        if name in ('.','..') or 'blocks' in l or ftype.startswith('D'):continue
        full=base+path.replace('\\\\','/')+'/'+name
        if full not in seen:
            seen.add(full)
            print(full)
" | tee -a "$auto_out"
    done
    echo "[+] Done: $auto_out" >&2
}

creds="$1"
user=$(echo "$creds" | python3 -c "import sys; c=sys.stdin.read().strip(); print(c.split('/')[1].split('%')[0] if '/' in c else c.split('%')[0])")
pass=$(echo "$creds" | python3 -c "import sys; c=sys.stdin.read().strip(); print(c.split('%')[1] if '%' in c else '')")
domain=$(echo "$creds" | python3 -c "import sys; c=sys.stdin.read().strip(); print(c.split('/')[0] if '/' in c else '')")

if [ "$2" = "-gui" ]; then
    pathsfile="${3:-}"
    python3 - "$creds" "$pathsfile" << 'PYEOF'
