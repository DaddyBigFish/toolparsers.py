  <div id=right>
    <div id=rightbar>
      <span>search in file:</span>
      <input type=text id=filtercontent placeholder="keyword,keyword... (comma = OR)" oninput=scheduleContentHL() title="highlight terms in the file content — comma separated terms use OR logic">
