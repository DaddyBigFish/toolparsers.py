    <div id=header>select a path</div>
    <div id=contentarea><pre id=content>click a path to view its contents</pre></div>
    <div id=bottom><button class=dl-btn onclick=dl()>[+] download file</button></div>
  </div>
</div>
<div id=status>0 paths</div>
<script>
let all=[],curPath=null,pathFilterTimer=null,contentHLTimer=null,lastContent='';

fetch('/paths').then(r=>r.json()).then(d=>{all=d;render(all);});

function loadFile(inp){
  const f=inp.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{all=ev.target.result.split('\\n').map(l=>l.trim()).filter(Boolean);render(all);};
  r.readAsText(f);
}

function loadManual(){
  const p=document.getElementById('manualpath').value.trim();
  if(!p)return;
  fetch('/loadfile?path='+encodeURIComponent(p))
    .then(r=>r.json())
    .then(d=>{
      if(d.ok){all=d.paths;render(all);}
      else document.getElementById('status').innerHTML='<span class=err>[-] '+d.msg+'</span>';
    });
}

// path filter - filters the list independently
function schedulePathFilter(){
  clearTimeout(pathFilterTimer);
  pathFilterTimer=setTimeout(applyPathFilter,150);
}

function applyPathFilter(){
  const val=document.getElementById('filterpath').value.trim();
  if(!val){render(all);return;}
  const terms=val.toLowerCase().split(',').map(t=>t.trim()).filter(Boolean);
  const filtered=all.filter(p=>terms.some(t=>p.toLowerCase().includes(t)));
  render(filtered);
}

// content search - highlights in open file independently, does not affect path list
function scheduleContentHL(){
  clearTimeout(contentHLTimer);
  contentHLTimer=setTimeout(applyContentHL,150);
}

function applyContentHL(){
  if(!lastContent)return;
  document.getElementById('content').innerHTML=highlight(lastContent);
  const hits=countHL(lastContent);
  const rbar=document.getElementById('rightbar');
  const old=rbar.querySelector('.hitcount');
  if(old)old.remove();
  if(hits>0){
    const s=document.createElement('span');
    s.className='hitcount';
    s.style.cssText='font-size:10px;color:#ff8;white-space:nowrap;margin-left:4px';
    s.textContent=hits+' match'+(hits===1?'':'es');
    rbar.appendChild(s);
  }
}

function render(paths){
  document.getElementById('status').textContent=paths.length+' / '+all.length+' paths';
  const list=document.getElementById('pathList');
  const renderID = Date.now();
  list.dataset.renderid=renderID;
  list.innerHTML='';
  let i=0;
  function chunk(){
    if(list.dataset.renderid!=renderID)return;
    const frag=document.createDocumentFragment();
    const end=Math.min(i+500,paths.length);
    for(;i<end;i++){
      const p=paths[i];
      const d=document.createElement('div');
      d.className='path';
      d.title=p;
      d.textContent=p;
      d.onclick=()=>sel(d,p);
      frag.appendChild(d);
    }
    list.appendChild(frag);
    if(i<paths.length)requestAnimationFrame(chunk);
  }
  chunk();
}

function proxy(){return document.getElementById('useProxy').checked?1:0;}

function escHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function escRe(s){return s.replace(/[.*+?^${}()|[\\]\\\\]/g,'\\\\$&');}

function highlight(text){
  const val=document.getElementById('filtercontent').value.trim();
  let result=escHtml(text);
  if(!val)return result;
  const terms=val.split(',').map(t=>t.trim()).filter(Boolean);
  terms.forEach(t=>{
    const re=new RegExp(escRe(escHtml(t)),'gi');
    result=result.replace(re,m=>'<span class=hl>'+m+'</span>');
  });
  return result;
}

function countHL(text){
  const val=document.getElementById('filtercontent').value.trim();
  if(!val)return 0;
  const terms=val.split(',').map(t=>t.trim()).filter(Boolean);
  let total=0;
  terms.forEach(t=>{
    const re=new RegExp(escRe(escHtml(t)),'gi');
    const matches=escHtml(text).match(re);
    if(matches)total+=matches.length;
  });
  return total;
}

function sel(el,path){
  document.querySelectorAll('.path').forEach(e=>e.classList.remove('active'));
  el.classList.add('active');
  curPath=path;
  document.getElementById('header').textContent=path;
  document.getElementById('content').textContent='loading...';
  document.getElementById('bottom').style.display='none';
  lastContent='';
  fetch('/cat?path='+encodeURIComponent(path)+'&proxy='+proxy())
    .then(r=>r.json())
    .then(d=>{
      const c=document.getElementById('content');
      if(d.ok){
        lastContent=d.content;
        c.innerHTML=highlight(d.content);
        const hits=countHL(d.content);
        const rbar=document.getElementById('rightbar');
        const old=rbar.querySelector('.hitcount');
        if(old)old.remove();
        if(hits>0){
          const s=document.createElement('span');
          s.className='hitcount';
          s.style.cssText='font-size:10px;color:#ff8;white-space:nowrap;margin-left:4px';
          s.textContent=hits+' match'+(hits===1?'':'es');
          rbar.appendChild(s);
        }
      } else {
        c.textContent=d.msg;
      }
      document.getElementById('bottom').style.display='block';
    });
}

function dl(){
  if(!curPath)return;
  document.getElementById('status').textContent='[*] downloading: '+curPath;
  fetch('/download?path='+encodeURIComponent(curPath)+'&proxy='+proxy())
    .then(r=>r.json())
    .then(d=>{
      document.getElementById('status').innerHTML=
        d.ok?'<span class=ok>[+] saved: '+d.msg+'</span>':'<span class=err>[-] failed: '+d.msg+'</span>';
    });
}

function clearRight(){
  curPath=null;
  lastContent='';
  document.getElementById('header').textContent='select a path';
  document.getElementById('content').textContent='click a path to view its contents';
  document.getElementById('bottom').style.display='none';
}
</script></body></html>"""

def run_cmd(cmd, use_proxy):
    if use_proxy:
        cmd = ['proxychains'] + cmd
    return subprocess.run(cmd, capture_output=True, text=True)

class Handler(BaseHTTPRequestHandler):
    def log_message(self, *a): pass
    def do_GET(self):
        p = urllib.parse.urlparse(self.path)
        qs = urllib.parse.parse_qs(p.query)
        use_proxy = qs.get('proxy',['0'])[0] == '1'

        if p.path == '/':
            self.send_response(200)
            self.send_header('Content-Type','text/html')
            self.end_headers()
            self.wfile.write(HTML.encode())

        elif p.path == '/paths':
            self.send_response(200)
            self.send_header('Content-Type','application/json')
            self.end_headers()
            self.wfile.write(json.dumps(paths).encode())

        elif p.path == '/loadfile':
            path = qs.get('path',[''])[0]
            self.send_response(200)
            self.send_header('Content-Type','application/json')
            self.end_headers()
            try:
                with open(path) as f:
                    loaded = [l.strip() for l in f if l.strip()]
                self.wfile.write(json.dumps({'ok':True,'paths':loaded}).encode())
            except Exception as e:
                self.wfile.write(json.dumps({'ok':False,'msg':str(e)}).encode())

        elif p.path == '/cat':
            path = qs.get('path',[''])[0]
            parts = path.split('/',4)
            share = '/'.join(parts[:4]) if len(parts)>=4 else path
            filepath = '/'+parts[4] if len(parts)>4 else '/'
            result = run_cmd(
                ['smbclient', share, '-U', creds, '-c', f'get "{filepath}" /tmp/smblist_preview'],
                use_proxy
            )
            self.send_response(200)
            self.send_header('Content-Type','application/json')
            self.end_headers()
            try:
                with open('/tmp/smblist_preview','rb') as f:
                    content = f.read().decode('utf-8', errors='replace')
                os.remove('/tmp/smblist_preview')
                self.wfile.write(json.dumps({'ok':True,'content':content}).encode())
            except:
                self.wfile.write(json.dumps({'ok':False,'msg':result.stderr.strip() or 'could not read file'}).encode())

        elif p.path == '/download':
            path = qs.get('path',[''])[0]
            parts = path.split('/',4)
            share = '/'.join(parts[:4]) if len(parts)>=4 else path
            filepath = '/'+parts[4] if len(parts)>4 else '/'
            d = os.path.dirname(filepath)
            f = os.path.basename(filepath)
            result = run_cmd(
                ['smbclient', share, '-U', creds, '-c', f'cd "{d}"; get "{f}"'],
                use_proxy
            )
            self.send_response(200)
            self.send_header('Content-Type','application/json')
            self.end_headers()
            if os.path.exists(f):
                self.wfile.write(json.dumps({'ok':True,'msg':f}).encode())
            else:
                self.wfile.write(json.dumps({'ok':False,'msg':result.stderr.strip()}).encode())

        else:
            self.send_response(404)
            self.end_headers()

port = 18888
print(f'[*] smblist gui at http://127.0.0.1:{port}')
print('[*] ctrl+c to stop')
threading.Timer(1, lambda: webbrowser.open(f'http://127.0.0.1:{port}')).start()
HTTPServer(('127.0.0.1', port), Handler).serve_forever()
PYEOF
    exit 0
fi

outfile=""
for i in "$@"; do
    if [ "$prev" = "-o" ]; then outfile="$i"; fi
    prev="$i"
done
[ -n "$outfile" ] && > "$outfile"

if [ "$2" = "-get" ]; then
    download_file "$3"
elif [ "$2" = "-nxc" ]; then
    parse_nxc "$3" | run_smblist
elif [ "$1" = "-nxc" ]; then
    parse_nxc "$2"
elif [ -n "$2" ] && [ "$2" != "-o" ]; then
    run_smblist < "$2"
else
    run_smblist
fi
